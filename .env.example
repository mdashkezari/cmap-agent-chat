# Frontend runtime config (Vite)
# Copy to .env.local

# Production API base
VITE_API_BASE_URL=https://agent.simonscmap.ai

# Optional: default LLM config sent in /chat requests
VITE_LLM_PROVIDER=openai
VITE_LLM_MODEL=gpt-4.1-mini

# Optional: UI behavior
VITE_MAX_TOOL_CALLS=8
VITE_RETURN_CODE=true
